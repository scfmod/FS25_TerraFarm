<?xml version="1.0" encoding="utf-8" standalone="no"?>
<modDesc descVersion="97">
    <author>scfmod</author>
    <version>1.5.0.1</version>
    <title>
        <en>TerraFarm</en>
    </title>
    <description>
        <en>
            <![CDATA[TerraFarm - The true landscaping experience]]>
        </en>
        <de>
            <![CDATA[TerraFarm - Das wahre Landschaftserlebnis]]>
        </de>
        <fr>
            <![CDATA[TerraFarm - Le simulateur de terrassement]]>
        </fr>
        <it>
            <![CDATA[TerraFarm - Simulatore Di Movimento Terra]]>
        </it>
    </description>

    <iconFilename>icon_terraFarm.dds</iconFilename>

    <multiplayer supported="true" />

    <specializations>
        <specialization name="machine" className="Machine" filename="scripts/specializations/Machine.lua" />
    </specializations>

    <extraSourceFiles>
        <sourceFile filename="scripts/main.lua" />
    </extraSourceFiles>

    <l10n filenamePrefix="l10n/l10n" />

    <actions>
        <action name="MACHINE_TOGGLE_ACTIVE" />
        <action name="MACHINE_TOGGLE_INPUT" />
        <action name="MACHINE_TOGGLE_OUTPUT" />
        <action name="MACHINE_SETTINGS" />
        <action name="MACHINE_SELECT_MATERIAL" />
        <action name="MACHINE_SELECT_TEXTURE" />
        <action name="MACHINE_SELECT_DISCHARGE_TEXTURE" />
        <action name="MACHINE_GLOBAL_SETTINGS" />
        <action name="MACHINE_TOGGLE_HUD" />
        <action name="MACHINE_SELECT_INPUT_AREA" />
        <action name="MACHINE_SELECT_OUTPUT_AREA" />
        <action name="MACHINE_TOGGLE_INPUT_AREA_STATE" />
        <action name="MACHINE_TOGGLE_OUTPUT_AREA_STATE" />
        <action name="MACHINE_GLOBAL_TOGGLE_BORDER" />

        <action name="AREA_EDITOR_ENTER" locked="true" />
        <action name="AREA_EDITOR_EXIT" locked="true" />
        <action name="AREA_EDITOR_PRIMARY" locked="true" />
        <action name="AREA_EDITOR_CANCEL" locked="true" />
        <action name="AREA_EDITOR_MOVE" locked="true" />
        <action name="AREA_EDITOR_DELETE" locked="true" />

        <action name="AREA_EDITOR_LEFT_RIGHT" locked="true" />
        <action name="AREA_EDITOR_UP_DOWN" locked="true" />
        <action name="AREA_EDITOR_PREV_NEXT" locked="true" />

        <action name="AREA_EDITOR_ANGLE" locked="true" />
        <action name="AREA_EDITOR_DIRECTION" locked="true" />
        <action name="AREA_EDITOR_LEVEL" locked="true" />
    </actions>

    <inputBinding>
        <actionBinding action="AREA_EDITOR_ENTER">
            <binding device="KB_MOUSE_DEFAULT" input="MOUSE_BUTTON_RIGHT" index="3" />
            <binding device="0_XINPUT_GAMEPAD" input="BUTTON_1" index="1" />
        </actionBinding>

        <actionBinding action="AREA_EDITOR_EXIT">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_esc" index="1" />
            <binding device="KB_MOUSE_DEFAULT" input="MOUSE_BUTTON_RIGHT" index="3" />
            <binding device="0_XINPUT_GAMEPAD" input="BUTTON_1" index="1" />
            <binding device="0_XINPUT_GAMEPAD" input="BUTTON_3" index="2" />
        </actionBinding>

        <actionBinding action="AREA_EDITOR_PRIMARY">
            <binding device="KB_MOUSE_DEFAULT" input="MOUSE_BUTTON_LEFT" index="3" />
            <binding device="0_XINPUT_GAMEPAD" input="BUTTON_2" index="1" />
        </actionBinding>

        <actionBinding action="AREA_EDITOR_CANCEL">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_esc" index="1" />
            <binding device="KB_MOUSE_DEFAULT" input="MOUSE_BUTTON_RIGHT" index="3" />
            <binding device="0_XINPUT_GAMEPAD" input="BUTTON_3" index="1" />
        </actionBinding>

        <actionBinding action="AREA_EDITOR_LEFT_RIGHT">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_left" axisComponent="-" neutralInput="0" index="1" />
            <binding device="KB_MOUSE_DEFAULT" input="KEY_right" axisComponent="+" neutralInput="0" index="1" />
            <binding device="0_XINPUT_GAMEPAD" input="BUTTON_20" axisComponent="-" neutralInput="0" index="1" />
            <binding device="0_XINPUT_GAMEPAD" input="BUTTON_18" axisComponent="+" neutralInput="0" index="1" />
        </actionBinding>

        <actionBinding action="AREA_EDITOR_UP_DOWN">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_up" axisComponent="+" neutralInput="0" index="1" />
            <binding device="KB_MOUSE_DEFAULT" input="KEY_down" axisComponent="-" neutralInput="0" index="1" />
            <binding device="0_XINPUT_GAMEPAD" input="BUTTON_17" axisComponent="+" neutralInput="0" index="1" />
            <binding device="0_XINPUT_GAMEPAD" input="BUTTON_19" axisComponent="-" neutralInput="0" index="1" />
        </actionBinding>

        <actionBinding action="AREA_EDITOR_PREV_NEXT">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_q" axisComponent="-" neutralInput="0" index="1" />
            <binding device="KB_MOUSE_DEFAULT" input="KEY_e" axisComponent="+" neutralInput="0" index="1" />
            <binding device="0_XINPUT_GAMEPAD" input="BUTTON_20" axisComponent="-" neutralInput="0" index="1" />
            <binding device="0_XINPUT_GAMEPAD" input="BUTTON_18" axisComponent="+" neutralInput="0" index="1" />
        </actionBinding>

        <actionBinding action="AREA_EDITOR_MOVE">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_f" index="1" />
            <binding device="0_XINPUT_GAMEPAD" input="BUTTON_4" index="1" />
        </actionBinding>

        <actionBinding action="AREA_EDITOR_DELETE">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_backspace" index="1" />
            <binding device="KB_MOUSE_DEFAULT" input="KEY_delete" index="2" />
            <binding device="0_XINPUT_GAMEPAD" input="BUTTON_9" index="1" />
        </actionBinding>

        <actionBinding action="AREA_EDITOR_ANGLE">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_lctrl" index="1" />
            <binding device="0_XINPUT_GAMEPAD" input="BUTTON_6" index="1" />
        </actionBinding>

        <actionBinding action="AREA_EDITOR_DIRECTION">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_lshift" index="1" />
            <binding device="0_XINPUT_GAMEPAD" input="BUTTON_5" index="1" />
        </actionBinding>

        <actionBinding action="AREA_EDITOR_LEVEL">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_lalt" index="1" />
            <binding device="0_XINPUT_GAMEPAD" input="BUTTON_11" index="1" />
        </actionBinding>

        <actionBinding action="MACHINE_TOGGLE_ACTIVE">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_o" index="1" />
            <binding device="0_XINPUT_GAMEPAD" input="BUTTON_5 BUTTON_19" index="1" />
        </actionBinding>
        <actionBinding action="MACHINE_SETTINGS">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_y" index="1" />
            <binding device="0_XINPUT_GAMEPAD" input="BUTTON_6 BUTTON_4" index="1" />
        </actionBinding>
        <actionBinding action="MACHINE_TOGGLE_INPUT">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_comma" index="1" />
            <binding device="0_XINPUT_GAMEPAD" input="BUTTON_5 BUTTON_4" index="1" />
        </actionBinding>
        <actionBinding action="MACHINE_TOGGLE_OUTPUT">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_minus" index="1" />
            <binding device="0_XINPUT_GAMEPAD" input="BUTTON_5 BUTTON_1" index="1" />
        </actionBinding>
        <actionBinding action="MACHINE_SELECT_MATERIAL">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_KP_0" index="1" />
        </actionBinding>
        <actionBinding action="MACHINE_SELECT_TEXTURE">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_KP_period" index="1" />
        </actionBinding>
        <actionBinding action="MACHINE_SELECT_DISCHARGE_TEXTURE">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_KP_8" index="1" />
        </actionBinding>

        <actionBinding action="MACHINE_SELECT_INPUT_AREA" />
        <actionBinding action="MACHINE_SELECT_OUTPUT_AREA" />

        <actionBinding action="MACHINE_TOGGLE_INPUT_AREA_STATE" />
        <actionBinding action="MACHINE_TOGGLE_OUTPUT_AREA_STATE" />

        <actionBinding action="MACHINE_GLOBAL_SETTINGS">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_KP_9" index="1" />
        </actionBinding>
        <actionBinding action="MACHINE_TOGGLE_HUD">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_KP_4" index="1" />
        </actionBinding>
        <actionBinding action="MACHINE_GLOBAL_TOGGLE_BORDER" />
    </inputBinding>
</modDesc>