<?xml version="1.0" encoding="utf-8" standalone="no"?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <Bitmap profile="tfEditor_menu" id="menuBox">
        <BoxLayout profile="tfEditor_menuHeader">
            <Bitmap profile="tfEditor_menuHeaderIconWaterplane" />
            <Text profile="tfEditor_menuHeaderText" text="$l10n_ui_waterPlane" />
        </BoxLayout>

        <BoxLayout profile="tfEditor_actionPanel" id="actionPanel">
            <Button profile="tfEditor_actionPanelButton" id="saveButton" onClick="onClickSave" text="$l10n_ui_editorSaveChanges">
            </Button>
            <Button profile="tfEditor_actionPanelButton" id="setTargetButton" onClick="onClickSetTargetHeight" text="$l10n_ui_moveArea">
            </Button>
            <Button profile="tfEditor_actionPanelButton" id="exitButton" onClick="onButtonMenuBack" text="$l10n_ui_exit">
            </Button>
        </BoxLayout>

        <BoxLayout profile="tfEditor_optionsPanel" id="optionsPanel">
            <Bitmap profile="tfEditor_optionSegment">
                <Text profile="tfEditor_optionSegmentTitle" text="$l10n_ui_name" />
                <TextInput focusOnHighlight="true" onEnterPressed="onEnterPressedNameInput" onEscPressed="onEnterPressedNameInput" id="nameInput" profile="tfEditor_textInputName">
                    <Bitmap profile="tfEditor_textInputBg" />
                    <Bitmap profile="fs25_textInputIconBox">
                        <Bitmap profile="fs25_textInputIcon" />
                    </Bitmap>
                </TextInput>
            </Bitmap>

            <Bitmap profile="tfEditor_optionSegment">
                <Text profile="tfEditor_optionSegmentTitle" text="$l10n_configuration_color" />
                <MultiTextOption id="colorOption" onClick="onClickColorOption" profile="tfEditor_multiTextOption" />
            </Bitmap>

            <Bitmap profile="tfEditor_optionSegment">
                <Text profile="tfEditor_optionSegmentTitle" text="$l10n_ui_visible" />
                <BinaryOption profile="tfEditor_binaryOption" onClick="onClickVisibleOption" id="visibleOption" />
            </Bitmap>

            <Bitmap profile="tfEditor_optionSegment">
                <Text profile="tfEditor_optionSegmentTitle" text="$l10n_ui_targetHeight" />
                <TextInput focusOnHighlight="true" onEnterPressed="onEnterPressedHeightInput" onEscPressed="onEnterPressedHeightInput" id="heightInput" profile="tfEditor_textInput">
                    <Bitmap profile="tfEditor_textInputBg" />
                    <Bitmap profile="fs25_textInputIconBox">
                        <Bitmap profile="fs25_textInputIcon" />
                    </Bitmap>
                </TextInput>
            </Bitmap>
        </BoxLayout>
    </Bitmap>

    <GuiElement profile="tfEditor_helpDisplay" id="helpDisplay" />

    <Text profile="tfEditor_positionText" id="positionText" />

    <GuiProfiles>
    </GuiProfiles>
</GUI>