<?xml version="1.0" encoding="utf-8" standalone="no"?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement profile="newLayer" />
    <Bitmap id="dialogBg" profile="dialogFullscreenBg" />
    <GuiElement id="dialogElement" profile="tfSetPosition_dialogBg">
        <ThreePartBitmap profile="fs25_dialogBgMiddleSmall" />
        <ThreePartBitmap profile="fs25_dialogBgTopSmall" />
        <ThreePartBitmap profile="fs25_dialogBgBottom" />
        <GuiElement profile="fs25_dialogContentContainer">
            <Text id="dialogTextElement" profile="fs25_textInputDialogText" text="" />

            <BoxLayout profile="tfSetPosition_dialogLayout">

                <TextInput focusInit="onOpen" maxCharacters="8" enterWhenClickOutside="false" id="inputElements[1]" onEnterPressed="onEnterPressedInput" onEscPressed="onEscPressed" profile="fs25_dialogTextInput">
                    <ThreePartBitmap profile="fs25_textInputBg" />
                    <Bitmap profile="fs25_dialogTextInputIconBox">
                        <Bitmap profile="fs25_dialogTextInputIcon" />
                    </Bitmap>
                    <Text profile="tfSetPosition_inputTitle" text="X" />
                </TextInput>

                <TextInput maxCharacters="8" enterWhenClickOutside="false" id="inputElements[2]" onEnterPressed="onEnterPressedInput" onEscPressed="onEscPressed" profile="fs25_dialogTextInput">
                    <ThreePartBitmap profile="fs25_textInputBg" />
                    <Bitmap profile="fs25_dialogTextInputIconBox">
                        <Bitmap profile="fs25_dialogTextInputIcon" />
                    </Bitmap>
                    <Text profile="tfSetPosition_inputTitle" text="Y" />
                </TextInput>

                <TextInput maxCharacters="8" enterWhenClickOutside="false" id="inputElements[3]" onEnterPressed="onEnterPressedInput" onEscPressed="onEscPressed" profile="fs25_dialogTextInput">
                    <ThreePartBitmap profile="fs25_textInputBg" />
                    <Bitmap profile="fs25_dialogTextInputIconBox">
                        <Bitmap profile="fs25_dialogTextInputIcon" />
                    </Bitmap>
                    <Text profile="tfSetPosition_inputTitle" text="Z" />
                </TextInput>

            </BoxLayout>
        </GuiElement>
        <BoxLayout id="buttonsPC" profile="fs25_dialogButtonBox">
            <Button id="yesButton" onClick="onClickOk" profile="buttonOK" text="$l10n_button_confirm" />
            <Bitmap profile="fs25_dialogButtonBoxSeparator" />
            <Button id="noButton" onClick="onClickBack" profile="buttonBack" text="$l10n_button_cancel" />
        </BoxLayout>
    </GuiElement>
    <GUIProfiles>
        <Profile name="tfSetPosition_dialogBg" extends="fs25_dialogBg">
            <size value="550px 300px" />
        </Profile>

        <Profile name="tfSetPosition_dialogLayout" with="anchorTopStretchingX">
            <height value="240px" />

            <flowDirection value="vertical" />
            <alignmentX value="center" />
            <alignmentY value="middle" />
            <elementSpacing value="8px" />
        </Profile>

        <Profile name="tfSetPosition_inputTitle" extends="textDefault" with="anchorMiddleLeft">
            <position value="-32px 0" />
            <size value="32px 32px" />
            <textSelectedColor value="1 1 1 1" />
            <textFocusedColor value="1 1 1 1" />
            <textHighlightedColor value="1 1 1 1" />
        </Profile>
    </GUIProfiles>
</GUI>