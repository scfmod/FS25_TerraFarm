<?xml version="1.0" encoding="UTF-8"?>
<GUI name="ingameMenuTerraFarm">
    <GuiElement profile="fs25_menuContainer">
        <GuiElement profile="fs25_menuHeaderPanel">
            <Bitmap profile="fs25_menuHeaderIconBg">
                <Bitmap profile="tfFrame_menuHeaderIcon" />
            </Bitmap>
            <Text profile="fs25_menuHeaderTitle" text="TerraFarm" />
        </GuiElement>
        <BoxLayout profile="fs25_subCategorySelectorTabbedBox" id="subCategoryBox">
            <Button profile="fs25_subCategorySelectorTabbedTab" id="subCategoryTabs[1]" text="$l10n_ui_machines" onClick="onClickMachines">
                <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background" />
            </Button>
            <Button profile="fs25_subCategorySelectorTabbedTab" id="subCategoryTabs[2]" text="$l10n_ui_landscapingAreas" onClick="onClickLandscapingAreas">
                <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background" />
            </Button>
            <Button profile="fs25_subCategorySelectorTabbedTab" id="subCategoryTabs[3]" text="$l10n_ui_waterPlanes" onClick="onClickWaterplanes">
                <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background" />
            </Button>
        </BoxLayout>
        <ThreePartBitmap profile="fs25_lineSeparatorTopHighlighted" position="0px -57px" />
        <MultiTextOption profile="fs25_subCategorySelectorTabbed" id="subCategoryPaging" position="0px -10px" onClick="updateSubCategoryPages" />

        <GuiElement profile="fs25_subCategorySelectorTabbedContainer" id="subCategoryPages[1]">
            <GuiElement profile="fs25_statisticsHeaderBox">
                <Text position="16px 0" profile="fs25_vehiclesHeaderName" text="$l10n_displayItem_machine" />
                <GuiElement position="448px 0px" profile="fs25_vehiclesHeaderTextContainer">
                    <Text profile="fs25_vehiclesHeaderText" text="$l10n_ui_operator" />
                </GuiElement>
                <GuiElement position="628px 0px" profile="fs25_vehiclesHeaderTextContainer">
                    <Text profile="fs25_vehiclesHeaderText" text="$l10n_ui_age" />
                </GuiElement>
                <GuiElement position="810px 0px" profile="fs25_vehiclesHeaderTextContainer">
                    <Text profile="fs25_vehiclesHeaderText" text="$l10n_ui_workingHours" />
                </GuiElement>
                <GuiElement position="988px 0px" profile="fs25_vehiclesHeaderTextContainer">
                    <Text profile="fs25_vehiclesHeaderText" text="$l10n_ui_condition" />
                </GuiElement>
                <GuiElement position="1166px 0px" profile="fs25_vehiclesHeaderTextContainer">
                    <Text profile="fs25_vehiclesHeaderText" text="$l10n_infohud_type" />
                </GuiElement>
                <GuiElement position="1340px 0px" profile="fs25_vehiclesHeaderTextContainer">
                    <Text profile="fs25_vehiclesHeaderText" text="$l10n_ui_missionStatusTitle" />
                </GuiElement>
                <ThreePartBitmap position="0px -2dp" profile="fs25_lineSeparatorBottom" />
            </GuiElement>
            <SmoothList profile="tfFrame_list" id="machinesList" onDoubleClick="onItemDoubleClick" wrapAround="true">
                <ListItem profile="fs25_vehiclesListItem" name="rowTemplate">
                    <ThreePartBitmap profile="fs25_vehiclesListItemBg" name="alternating" />
                    <Text profile="fs25_vehiclesListItemName" position="16px 0px" name="name" />
                    <Text profile="fs25_vehiclesListItemInfo" position="440px 0px" name="operator" />
                    <Text profile="fs25_vehiclesListItemInfo" position="620px 0px" name="age" />
                    <Text profile="fs25_vehiclesListItemInfo" position="800px 0px" name="operatingHours" />
                    <Text profile="fs25_vehiclesListItemInfo" position="980px 0px" name="damage" />
                    <Text profile="fs25_vehiclesListItemInfo" position="1160px 0px" name="type" />
                    <Text profile="fs25_vehiclesListItemInfo" position="1330px 0px" name="status" />
                </ListItem>
            </SmoothList>
            <GuiElement id="detailBox" profile="tfFrame_detailsContainer">
                <Bitmap name="startClipper" position="-2px 140px" profile="fs25_stopClipper" />
                <Bitmap profile="tfFrame_detailsImageBg">
                    <Bitmap id="itemDetailsImage" profile="tfFrame_detailsImage" />
                </Bitmap>
                <Text id="itemDetailsName" profile="tfFrame_detailsName" />
            </GuiElement>
        </GuiElement>
        <GuiElement profile="fs25_subCategorySelectorTabbedContainer" id="subCategoryPages[2]">
            <GuiElement profile="fs25_statisticsHeaderBox">
                <Text position="16px 0" profile="fs25_vehiclesHeaderName" text="$l10n_ui_name" />
                <GuiElement position="440px 0px" profile="fs25_vehiclesHeaderTextContainer">
                    <Text profile="fs25_vehiclesHeaderText" text="" />
                </GuiElement>
                <GuiElement position="620px 0px" profile="fs25_vehiclesHeaderTextContainer">
                    <Text profile="fs25_vehiclesHeaderText" text="" />
                </GuiElement>
                <GuiElement position="800px 0px" profile="fs25_vehiclesHeaderTextContainer">
                    <Text profile="fs25_vehiclesHeaderText" text="" />
                </GuiElement>
                <GuiElement position="1110px 0px" profile="fs25_vehiclesHeaderTextContainer">
                    <Text profile="fs25_vehiclesHeaderText" text="$l10n_infohud_type" />
                </GuiElement>
                <GuiElement position="1340px 0px" profile="fs25_vehiclesHeaderTextContainer">
                    <Text profile="fs25_vehiclesHeaderText" text="$l10n_ui_missionStatusTitle" />
                </GuiElement>
                <ThreePartBitmap position="0px -2dp" profile="fs25_lineSeparatorBottom" />
            </GuiElement>
            <SmoothList profile="tfFrame_list" id="areasList" onDoubleClick="onItemDoubleClick" wrapAround="true" height="716px">
                <ListItem profile="fs25_vehiclesListItem" name="rowTemplate">
                    <ThreePartBitmap profile="fs25_vehiclesListItemBg" name="alternating" />
                    <Bitmap profile="tfFrame_areasListItemImage" position="56px 0px" name="icon" />
                    <Text profile="fs25_vehiclesListItemName" position="64px 0" name="name" />
                    <Text profile="fs25_vehiclesListItemInfo" position="440px 0px" name="licensePlate" />
                    <Text profile="fs25_vehiclesListItemInfo" position="620px 0px" name="age" />
                    <Text profile="fs25_vehiclesListItemInfo" position="800px 0px" name="operatingHours" />
                    <Text profile="fs25_vehiclesListItemInfo" position="980px 0px" name="damage" />
                    <Text profile="fs25_vehiclesListItemInfo" position="1100px 0px" name="type" />
                    <Text profile="fs25_vehiclesListItemInfo" position="1330px 0px" name="status" />
                </ListItem>
            </SmoothList>
        </GuiElement>
        <GuiElement profile="fs25_subCategorySelectorTabbedContainer" id="subCategoryPages[3]">
            <GuiElement profile="fs25_statisticsHeaderBox">
                <Text position="16px 0" profile="fs25_vehiclesHeaderName" text="$l10n_ui_name" />
                <GuiElement position="1340px 0px" profile="fs25_vehiclesHeaderTextContainer">
                    <Text profile="fs25_vehiclesHeaderText" text="$l10n_ui_missionStatusTitle" />
                </GuiElement>
                <ThreePartBitmap position="0px -2dp" profile="fs25_lineSeparatorBottom" />
            </GuiElement>
            <SmoothList profile="tfFrame_list" id="waterplanesList" onDoubleClick="onItemDoubleClick" wrapAround="true" height="716px">
                <ListItem profile="fs25_vehiclesListItem" name="rowTemplate">
                    <ThreePartBitmap profile="fs25_vehiclesListItemBg" name="alternating" />
                    <Text profile="fs25_vehiclesListItemName" position="16px 0" name="name" />
                    <Text profile="fs25_vehiclesListItemInfo" position="1330px 0px" name="status" />
                </ListItem>
            </SmoothList>
        </GuiElement>
    </GuiElement>

    <ThreePartBitmap profile="fs25_sliderDockedBg" handleFocus="false" position="-125px 20px">
        <ThreePartBitmap profile="fs25_sliderDockedBox">
            <Slider profile="fs25_sliderDocked" id="listSlider" dataElementId="machinesList" />
        </ThreePartBitmap>
    </ThreePartBitmap>

    <GuiProfiles>
        <Profile name="tfFrame_list" extends="fs25_vehiclesList" with="anchorTopStretchingX">
            <height value="512px" />
        </Profile>

        <Profile name="tfFrame_areasListItemImage" extends="baseReference" with="anchorMiddleLeft">
            <size value="32px 32px" />
            <imageSliceId value="terraFarm.icon_excavator" />
            <imageSelectedColor value="$preset_fs25_colorMainDark" />
        </Profile>
        <Profile name="tfFrame_menuHeaderIcon" extends="fs25_menuHeaderIcon">
            <imageSliceId value="terraFarm.icon_excavator" />
        </Profile>
        <Profile name="tfFrame_menuContainer" extends="fs25_menuContainer">
            <position value="-76px 80px" />
        </Profile>

        <Profile name="tfFrame_detailsContainer" extends="fs25_shopItemsDetailsContainer">
            <height value="150px" />
        </Profile>

        <Profile name="tfFrame_detailsImageBg" extends="fs25_vehiclesDetailsImageBg">
            <size value="170px 170px" />
            <position value="0px -35px" />
        </Profile>

        <Profile name="tfFrame_detailsImage" extends="fs25_vehiclesDetailsImage">
            <size value="125px 125px" />
        </Profile>

        <Profile name="tfFrame_detailsName" extends="fs25_vehiclesDetailsName">
            <absoluteSizeOffset value="520px 0px" />
            <position value="190px -30px" />
            <textSize value="24px" />
        </Profile>

        <Profile name="tfFrame_list" extends="fs25_vehiclesList">
            <position value="0px -34px" />
            <absoluteSizeOffset value="0px 175px" />
        </Profile>
    </GuiProfiles>
</GUI>